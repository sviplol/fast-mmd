{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fast MMD",
  "version": "1.0.0",
  "identifier": "cn.2bbb.fastmmd",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GLM API 平台登录器",
        "width": 900,
        "height": 650,
        "resizable": true,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
